# Server
PORT=4000

# Web
WEB_PORT=3000
SERVER_URL=http://localhost:4000

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for Whisper STT
OPENAI_API_KEY=sk-...

# Model routing: auto | sonnet | haiku (default: auto)
# auto = Haiku for simple queries, Sonnet for tool-heavy ones
# CLAUDE_MODEL=auto

# STT provider: openai | local (default: openai)
# STT_PROVIDER=openai

# Local Whisper settings (only used when STT_PROVIDER=local)
# Path to whisper.cpp model file (required for local provider)
# WHISPER_MODEL_PATH=/models/ggml-base.en.bin
# Path to whisper-cpp binary (default: whisper-cpp)
# WHISPER_BINARY=whisper-cpp

# TTS provider: openai | google | piper (default: openai)
# TTS_PROVIDER=openai

# OpenAI TTS voice (when TTS_PROVIDER=openai)
# TTS_VOICE=nova

# Google Cloud TTS (when TTS_PROVIDER=google)
# GOOGLE_TTS_CREDENTIALS={"type":"service_account",...}
# GOOGLE_TTS_VOICE=en-US-Standard-C
# GOOGLE_TTS_SPEAKING_RATE=1.0

# Piper TTS (when TTS_PROVIDER=piper)
# PIPER_BINARY=piper                          # path to piper binary (default: piper)
# PIPER_MODEL=/models/en_US-lessac-high.onnx  # path to .onnx voice model (required)
# PIPER_VOICE=                                # speaker name for multi-speaker models

# Working directory for Claude tool execution (defaults to cwd)
# WORK_DIR=/path/to/your/projects
